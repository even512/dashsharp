# Dash# – optionale Umgebungsvariablen
# -------------------------------------------------------------------
# Fuer den normalen Betrieb NICHT noetig: konfiguriere Integrationen
# bequem in der Weboberflaeche unter /settings (wird in config/secrets.json
# im gemounteten Volume gespeichert).
#
# Diese Datei ist nur eine Vorlage. Fuer lokale Entwicklung:
#   cp .env.example .env   und Werte eintragen.
# Gesetzte Env-Variablen haben Vorrang vor den in der UI gespeicherten Werten.
# -------------------------------------------------------------------

# HTTP-Port im Container (Standard 3000; Host-Port wird in Docker/Unraid gemappt)
PORT=3000
# Zeitzone
TZ=Europe/Berlin

# --- System / Docker -------------------------------------------------
# Glances REST-API (liefert CPU/RAM/Disk/Netzwerk + Docker-Container)
GLANCES_URL=
# Optional: fester Hostname fuers System-Panel, falls Glances nur eine
# Container-ID meldet (kein --uts=host)
GLANCES_LABEL=

# --- Netzwerk-Durchsatz (Live-Kachel) --------------------------------
# Quelle fuer die Live-Netzwerkzahlen der "Network Throughput"-Kachel:
#   auto    = /proc/net/dev per Unraid-SSH streamen, sonst Glances (Standard)
#   ssh     = nur SSH (kein Glances-Fallback fuers Netz)
#   glances = immer Glances (kein SSH-Sampler)
# SSH liest denselben Kernel-Zaehler wie Unraids eigenes Dashboard (inkl.
# bridged Docker-/VM-Traffic ueber br0) -> echt fluessig. Nutzt die
# UNRAID_SSH_*-Zugangsdaten weiter unten.
NET_SOURCE=auto
# Interface fuer den Durchsatz (leer = automatisch das mit dem meisten
# Traffic, i.d.R. br0/bond0). Beispiel: br0
NET_IFACE=
# Sample-Intervall des SSH-/proc-net-dev-Samplers in ms (250..4000)
NET_SAMPLE_MS=500
# Wie lange der Netz-Verlauf im Server vorgehalten wird (fuer 10m/1h-Ansicht)
NET_HISTORY_MS=3600000
# WAN-Sampler (Internet-Durchsatz vom UniFi-Gateway, nutzt UNIFI_API_KEY):
# Poll-Intervall in ms solange ein Browser zuschaut (500..60000) bzw. im
# Leerlauf (haelt den WAN-Verlauf fuer den Backfill warm).
WAN_SAMPLE_MS=1000
WAN_IDLE_MS=15000

# --- AdGuard Home ----------------------------------------------------
ADGUARD_URL=
ADGUARD_USER=
ADGUARD_PASS=

# --- Plex ------------------------------------------------------------
PLEX_URL=
PLEX_TOKEN=

# --- Wetter (Open-Meteo, kein API-Key noetig) ------------------------
WEATHER_CITY=
WEATHER_UNIT=C

# --- UniFi (Cloud-API, api.ui.com) -----------------------------------
UNIFI_API_KEY=
UNIFI_HOST_ID=
UNIFI_CAMERA_ID=

# --- UniFi lokal (optional, empfohlen fuer Live-WAN) -----------------
# Liest den Live-WAN-Durchsatz direkt von der UniFi-OS-Console im LAN.
# Der Server haelt dazu — wie das native UniFi-Panel — eine dauerhafte
# Websocket-Subscription offen (wss://.../proxy/network/wss/s/<site>/events)
# und bekommt so echten Sekundentakt. Ohne aktive Subscription berechnet die
# Console die WAN-Rate nur grob (~5-10 s), weshalb reines REST-Polling nicht
# ausreicht. Empfohlen: ein dediziertes read-only Konto (Viewer). Ist dies
# gesetzt, nutzt der WAN-Sampler den lokalen Websocket; sonst faellt er auf
# das (grobe) Cloud-stat/health-Polling zurueck.
# Kann auch komplett ueber die UI (Einstellungen -> UniFi) gepflegt werden.
UNIFI_LOCAL_URL=
UNIFI_LOCAL_USER=
UNIFI_LOCAL_PASS=
# Interne Site-ID (i.d.R. "default"), nur bei mehreren Sites noetig:
UNIFI_LOCAL_SITE=default
# Diagnose: rohe UniFi-Websocket-Nachrichtentypen ins Log schreiben (1/true).
# Hilft, das Device-Nachrichtenschema der eigenen Firmware zu pruefen.
WAN_WS_DEBUG=

# --- UniFi Gateway SSH (optional, praeziseste WAN-Quelle) ------------
# Liest den WAN-Durchsatz direkt aus /proc/net/dev der Console per SSH und
# rechnet die Rate selbst im Sekundentakt aus dem Delta — echt-Echtzeit,
# akkurat (nie ueber Leitungskapazitaet), unabhaengig von der Controller-
# Kadenz. Ist dies gesetzt, wird es zur primaeren Quelle; der lokale
# Websocket bleibt als automatischer Fallback und ueberbrueckt SSH-Ausfaelle.
# Voraussetzung: SSH an der Console aktivieren (UniFi OS -> Console -> SSH).
UNIFI_GW_SSH_HOST=            # leer -> Hostname aus UNIFI_LOCAL_URL
UNIFI_GW_SSH_PORT=22
UNIFI_GW_SSH_USER=root
UNIFI_GW_SSH_PASSWORD=
# Alternativ statt Passwort ein privater SSH-Key (PEM-Inhalt):
UNIFI_GW_SSH_KEY=
# WAN-Interface am Gateway. Leer = Auto-Erkennung ueber die Default-Route
# (z. B. eth4 bei DHCP, ppp0 bei PPPoE). Nur bei exotischem Setup manuell:
UNIFI_GW_WAN_IFACE=

# --- Nextcloud -------------------------------------------------------
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
NEXTCLOUD_SHARE_PATH=

# --- Unraid (offizielle GraphQL-API, ab Unraid 7.2) ------------------
# URL der Unraid-Weboberflaeche (z.B. http://tower.local oder http://192.168.1.10)
UNRAID_URL=
# API-Key: API im Unraid aktivieren, dann `unraid-api apikey --create`
# (oder ueber die Unraid-UI) erzeugen. Speist alle Unraid-Kacheln
# (VMs, Docker, Array/Disks, Shares, Meldungen, System, USV).
UNRAID_API_KEY=
# Riskante Steuer-Aktionen freischalten (Array stoppen/starten, Parity-
# Steuerung, Server-Neustart/-Shutdown): 'true' = an, sonst gesperrt.
# Wird serverseitig durchgesetzt; auch ueber Settings -> Unraid schaltbar.
UNRAID_DANGER_ACTIONS=
# Optional: SSH-Zugang fuer den DIREKTEN VNC-Zugriff (noVNC-Konsole ohne
# Unraid-Login, eingebettet im Dashboard). Ohne SSH oeffnet der VNC-Button
# Unraids VM-Manager (mit Login). Gibt Dash# SSH-Zugriff auf Unraid – nur im
# vertrauenswuerdigen LAN nutzen.
UNRAID_SSH_HOST=          # leer = Host aus UNRAID_URL
UNRAID_SSH_PORT=22
UNRAID_SSH_USER=root
UNRAID_SSH_PASSWORD=      # entweder Passwort ...
UNRAID_SSH_KEY=           # ... oder privater SSH-Key (PEM, mehrzeilig)
