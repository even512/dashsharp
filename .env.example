# Dash# – optionale Umgebungsvariablen
# -------------------------------------------------------------------
# Fuer den normalen Betrieb NICHT noetig: konfiguriere Integrationen
# bequem in der Weboberflaeche unter /settings (wird in config/secrets.json
# im gemounteten Volume gespeichert).
#
# Diese Datei ist nur eine Vorlage. Fuer lokale Entwicklung:
#   cp .env.example .env   und Werte eintragen.
# Gesetzte Env-Variablen haben Vorrang vor den in der UI gespeicherten Werten.
# -------------------------------------------------------------------

# HTTP-Port im Container (Standard 3000; Host-Port wird in Docker/Unraid gemappt)
PORT=3000
# Zeitzone
TZ=Europe/Berlin

# --- System / Docker -------------------------------------------------
# Glances REST-API (liefert CPU/RAM/Disk/Netzwerk + Docker-Container)
GLANCES_URL=

# --- AdGuard Home ----------------------------------------------------
ADGUARD_URL=
ADGUARD_USER=
ADGUARD_PASS=

# --- Plex ------------------------------------------------------------
PLEX_URL=
PLEX_TOKEN=

# --- Wetter (Open-Meteo, kein API-Key noetig) ------------------------
WEATHER_CITY=
WEATHER_UNIT=C

# --- UniFi (Cloud-API, api.ui.com) -----------------------------------
UNIFI_API_KEY=
UNIFI_HOST_ID=
UNIFI_CAMERA_ID=

# --- Nextcloud -------------------------------------------------------
NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASS=
NEXTCLOUD_SHARE_PATH=
